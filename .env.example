DISCORD_TOKEN=
# Optional: set this for instant command registration in one Discord server.
DISCORD_GUILD_ID=
# Role assigned after a successful /bind.
ROLE_ID=

MINECRAFT_DATA_DIR=/minecraft-data
BOT_DATA_DIR=/bot-data
BINDINGS_PATH=/bot-data/bindings.json

MC_RCON_HOST=mc
MC_RCON_PORT=25575
MC_RCON_PASSWORD=
MC_RCON_TIMEOUT_SECONDS=5

# Optional: requires the privileged Server Members Intent in the Discord developer portal.
DISCORD_JOIN_DM=false
